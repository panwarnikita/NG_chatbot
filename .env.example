# Google OAuth Configuration
GOOGLE_CLIENT_ID = your_google_client_id_here
GOOGLE_CLIENT_SECRET = your_google_client_secret_here

# NVIDIA AI Endpoints API
NVIDIA_API_KEY = your_nvidia_api_key_here

# Flask Configuration
FLASK_ENV = development
FLASK_DEBUG = 1
PORT = 5000

# Qdrant Vector Database Configuration
QDRANT_COLLECTION = navgurukul_docs
QDRANT_URL = https://your-qdrant-instance.qdrant.io:6333
QDRANT_API_KEY = your_qdrant_api_key_here
QDRANT_TIMEOUT = 180
QDRANT_BATCH_SIZE = 16

# RAG Configuration
RAG_TOP_K = 4
RAG_MAX_CONTEXT_CHARS = 2200
CHAT_HISTORY_MESSAGES = 4

# LLM Configuration
NVIDIA_PRIMARY_MODEL = meta/llama-3.1-8b-instruct
NVIDIA_FALLBACK_MODEL = meta/llama-3.3-70b-instruct
LLM_MAX_TOKENS = 280
